# App mode — flowers-only back office
# Demo deploy: flower_demo (local storage, one-tap login)
VITE_APP_MODE=flower_demo

# Production go-live (Vercel example):
# VITE_APP_MODE=cafe
# VITE_FLOWER_STORAGE_MODE=supabase
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase (required for production shared data)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Storage mode overrides (default: auto — uses Supabase when configured, else local)
# VITE_PRODUCT_STORAGE_MODE=auto|local|supabase
# VITE_ORDER_STORAGE_MODE=auto|local|supabase
# VITE_FLOWER_STORAGE_MODE=auto|local|supabase
