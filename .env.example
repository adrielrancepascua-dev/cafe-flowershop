# App deployment mode
# Allowed values:
# - cafe (default behavior)
# - flower_demo (flower dashboard-only demo)
VITE_APP_MODE=cafe

# Supabase (optional for demo — local fallback works without these)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Storage mode overrides (default: auto — uses Supabase when configured, else local)
# VITE_PRODUCT_STORAGE_MODE=auto|local|supabase
# VITE_ORDER_STORAGE_MODE=auto|local|supabase
# VITE_FLOWER_STORAGE_MODE=auto|local|supabase
